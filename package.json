{
  "name": "bitbadges-builder-mcp",
  "version": "5.0.6",
  "description": "MCP server for building BitBadges collections with embedded documentation and API tools",
  "type": "module",
  "main": "./dist/tools/index.js",
  "types": "./dist/tools/index.d.ts",
  "bin": {
    "bitbadges-builder-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.js"
    },
    "./tools": {
      "types": "./dist/tools/index.d.ts",
      "default": "./dist/tools/index.js"
    },
    "./skills": {
      "types": "./dist/resources/skillInstructions.d.ts",
      "default": "./dist/resources/skillInstructions.js"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
      "default": "./dist/resources/index.js"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "default": "./dist/sdk/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "typesVersions": {
    "*": {
      "tools": [
        "dist/tools/index.d.ts"
      ],
      "skills": [
        "dist/resources/skillInstructions.d.ts"
      ],
      "resources": [
        "dist/resources/index.d.ts"
      ],
      "sdk": [
        "dist/sdk/index.d.ts"
      ],
      "server": [
        "dist/server.d.ts"
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bitbadges/bitbadges-builder-mcp.git"
  },
  "homepage": "https://github.com/bitbadges/bitbadges-builder-mcp#readme",
  "bugs": {
    "url": "https://github.com/bitbadges/bitbadges-builder-mcp/issues"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "bitbadges",
    "mcp",
    "model-context-protocol",
    "claude",
    "blockchain",
    "tokenization",
    "nft",
    "cosmos",
    "stablecoin",
    "smart-token"
  ],
  "author": "BitBadges",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bech32": "^2.0.0",
    "bitbadgesjs-sdk": "^0.31.3",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
